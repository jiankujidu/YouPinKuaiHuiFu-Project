<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- 应用主题 -->
    <style name="Theme.WeChatQuickReply" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/bg_gray</item>
        <item name="android:statusBarColor">@color/bg_gray</item>
    </style>
    
    <!-- 无 ActionBar 主题 -->
    <style name="Theme.WeChatQuickReply.NoActionBar" parent="Theme.WeChatQuickReply">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- 标题样式 -->
    <style name="WeChatTitle">
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#000000</item>
    </style>
    
    <!-- Tab 样式 -->
    <style name="WeChatTab">
        <item name="android:textSize">14sp</item>
    </style>
    
</resources>
